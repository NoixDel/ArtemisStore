<%- include('partials/headers', {page_title: "Parametres"}) %>

<style>
    .settings-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 16px;
    }

    .setting-card {
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 18px;
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.05);
    }

    .setting-card.wide {
        grid-column: 1 / -1;
    }

    .setting-card label {
        display: block;
        margin-bottom: 6px;
        font-weight: 750;
        color: #111827;
    }

    .setting-card p {
        margin: 0 0 12px;
        color: #6b7280;
        font-size: 0.92rem;
    }

    .setting-actions {
        display: flex;
        gap: 10px;
        align-items: center;
        flex-wrap: wrap;
        margin-top: 12px;
    }

    #applicationsDbSources {
        min-height: 110px;
        font-family: Consolas, "Courier New", monospace;
        font-size: 0.9rem;
    }

    #status {
        min-height: 24px;
        margin-top: 16px;
        font-weight: 650;
    }
</style>

<div class="settings-grid">
    <section class="setting-card">
        <label for="autoUpdate">Mise a jour de l'application</label>
        <p>Recherche automatiquement les nouvelles versions d'ArtemisStore.</p>
        <select id="autoUpdate" class="form-select">
            <option value="true">Activee</option>
            <option value="false">Desactivee</option>
        </select>
    </section>

    <section class="setting-card">
        <label for="AllwaysShowTerminal">Afficher le terminal</label>
        <p>Affiche les fenetres de commande pendant les installations, suppressions et mises a jour.</p>
        <select id="AllwaysShowTerminal" class="form-select">
            <option value="true">Oui</option>
            <option value="false">Non</option>
        </select>
    </section>

    <section class="setting-card">
        <label for="updateAppsOnLogin">Mises a jour a l'ouverture de session</label>
        <select id="updateAppsOnLogin" class="form-select">
            <option value="true">Activee</option>
            <option value="false">Desactivee</option>
        </select>
    </section>

    <section class="setting-card wide">
        <label for="applicationsDbSources">Sources applications.db</label>
        <p>Une URL par ligne. Les liens GitHub classiques sont convertis automatiquement en liens raw.</p>
        <textarea id="applicationsDbSources" class="form-control" spellcheck="false"></textarea>
        <div class="setting-actions">
            <button id="saveDbSourcesBtn" class="btn btn-primary">Enregistrer les sources</button>
            <button id="refreshDbBtn" class="btn btn-outline-primary">Forcer l'actualisation</button>
            <span id="dbStatus" class="text-muted"></span>
        </div>
    </section>
</div>

<div id="status" class="text-success"></div>

<script>
    const booleanFields = ['autoUpdate', 'AllwaysShowTerminal', 'updateAppsOnLogin'];
    const dbSourcesField = document.getElementById('applicationsDbSources');

    function applySettings(settings) {
        booleanFields.forEach((field) => {
            document.getElementById(field).value = Boolean(settings[field]).toString();
        });

        const sources = Array.isArray(settings.applicationsDbSources)
            ? settings.applicationsDbSources
            : [];
        dbSourcesField.value = sources.join('\n');
    }

    function showStatus(message, isError = false) {
        const status = document.getElementById('status');
        status.classList.toggle('text-danger', isError);
        status.classList.toggle('text-success', !isError);
        status.textContent = message;
        setTimeout(() => (status.textContent = ''), 2800);
    }

    window.electron.send('get-settings');

    window.electron.on('settings-data', applySettings);

    window.electron.on('setting-updated', ({ key, settings, error }) => {
        if (settings) applySettings(settings);
        showStatus(error ? `${key} non applique : ${error}` : 'Parametre mis a jour', Boolean(error));
    });

    window.electron.on('applications-db-refresh-result', ({ success, result, error }) => {
        const dbStatus = document.getElementById('dbStatus');
        document.getElementById('refreshDbBtn').disabled = false;
        if (!success) {
            dbStatus.className = 'text-danger';
            dbStatus.textContent = error || 'Actualisation impossible';
            return;
        }

        dbStatus.className = 'text-success';
        dbStatus.textContent = result.updated
            ? 'Base applications mise a jour'
            : 'Base applications deja a jour';
    });

    booleanFields.forEach((field) => {
        document.getElementById(field).addEventListener('change', (event) => {
            window.electron.send('update-setting', field, event.target.value === 'true');
        });
    });

    document.getElementById('saveDbSourcesBtn').addEventListener('click', () => {
        const sources = dbSourcesField.value
            .split(/\r?\n/)
            .map((line) => line.trim())
            .filter(Boolean);
        window.electron.send('update-setting', 'applicationsDbSources', sources);
    });

    document.getElementById('refreshDbBtn').addEventListener('click', () => {
        const button = document.getElementById('refreshDbBtn');
        const dbStatus = document.getElementById('dbStatus');
        button.disabled = true;
        dbStatus.className = 'text-muted';
        dbStatus.textContent = 'Actualisation en cours...';
        window.electron.send('refresh-applications-db');
    });
</script>

<%- include('partials/footers') %>
